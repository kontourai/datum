{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/kontourai/datum/datum.schema.json",
  "title": "Datum registry config",
  "description": "AI provider/model/role registry. Answers which backend, which model, whose key, what base URL. Auth is by reference only (env var name, macOS Keychain, or 1Password); never embed a literal secret.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "providers": {
      "type": "object",
      "description": "Provider id -> provider definition.",
      "additionalProperties": { "$ref": "#/$defs/Provider" }
    },
    "roles": {
      "type": "object",
      "description": "Role name -> fixed model ref or inventory-ranked capability policy.",
      "additionalProperties": { "$ref": "#/$defs/Role" }
    },
    "capabilityCatalog": {
      "description": "Optional Bearing capability-catalog source. Exactly one remote snapshot URL or local snapshot path.",
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["remoteUrl"],
          "properties": {
            "remoteUrl": {
              "type": "string",
              "format": "uri",
              "pattern": "^[Hh][Tt][Tt][Pp][Ss]?://[^/?#@\\s]+(?:/[^?#\\s]*)?$",
              "description": "Credential-free http(s) snapshot endpoint without userinfo, query parameters, or a fragment."
            },
            "maxAgeSeconds": { "type": "number", "exclusiveMinimum": 0 }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["localPath"],
          "properties": {
            "localPath": {
              "type": "string",
              "minLength": 1,
              "pattern": "^(?![/\\\\])(?!.*(?:^|[/\\\\])\\.\\.(?:[/\\\\]|$)).+$",
              "description": "Repository-relative snapshot path without parent traversal."
            },
            "maxAgeSeconds": { "type": "number", "exclusiveMinimum": 0 }
          }
        }
      ]
    }
  },
  "$defs": {
    "Provider": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "auth", "models"],
      "properties": {
        "kind": {
          "type": "string",
          "description": "Open enum. 'anthropic-compatible' and 'openai-compatible' are implemented; any string is accepted so new kinds can land. Not every consumer supports every kind (see README matrix).",
          "examples": ["anthropic-compatible", "openai-compatible"]
        },
        "baseUrl": {
          "type": "string",
          "description": "Optional. Absent = SDK default for that kind.",
          "format": "uri"
        },
        "auth": { "$ref": "#/$defs/Auth" },
        "models": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" },
          "description": "Model ids offered by this provider."
        }
      }
    },
    "Auth": {
      "description": "Auth by reference only: exactly one of env / keychain / op. Never the key itself; a literal-secret-looking value is rejected by the validator.",
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["env"],
          "properties": {
            "env": {
              "type": "string",
              "pattern": "^[A-Z][A-Z0-9_]*$",
              "description": "Name of the environment variable holding the API key. NEVER the key itself."
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["keychain"],
          "properties": {
            "keychain": {
              "type": "object",
              "additionalProperties": false,
              "required": ["service"],
              "properties": {
                "service": { "type": "string", "minLength": 1, "description": "macOS Keychain generic-password service name." },
                "account": { "type": "string", "minLength": 1, "description": "Optional Keychain account name." }
              },
              "description": "macOS Keychain reference (darwin-only), resolved lazily via `security find-generic-password -w`."
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["op"],
          "properties": {
            "op": {
              "type": "string",
              "pattern": "^op://[^/\\s]+/[^/\\s]+/[^\\s]+$",
              "description": "1Password secret reference (op://vault/item/field), resolved lazily via `op read`."
            }
          }
        }
      ]
    },
    "Role": {
      "oneOf": [
        { "type": "string", "pattern": "^[^@\\s]+(@[^@\\s]+)?$" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["policy"],
          "properties": {
            "policy": {
              "type": "object",
              "additionalProperties": false,
              "required": ["requirements", "preferences", "locality"],
              "properties": {
                "requirements": { "type": "array", "maxItems": 64, "items": { "$ref": "#/$defs/RankRequirement" } },
                "preferences": { "type": "array", "maxItems": 64, "items": { "$ref": "#/$defs/RankPreference" } },
                "locality": { "enum": ["local-only", "remote-allowed"] },
                "fallback": { "type": "string", "minLength": 1, "maxLength": 256, "pattern": "^[^@\\s]+(@[^@\\s]+)?$" }
              }
            }
          }
        }
      ]
    },
    "SourceClasses": {
      "type": "array",
      "minItems": 1,
      "maxItems": 2,
      "uniqueItems": true,
      "items": { "enum": ["first-party", "external"] }
    },
    "RankRequirement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["measurementKey", "aggregation", "operator", "value"],
      "properties": {
        "measurementKey": { "type": "string", "minLength": 1, "maxLength": 256, "pattern": "^(?=\\S)(?!.*[\\u0000-\\u001f]).*\\S$" },
        "aggregation": { "enum": ["fact", "mean", "min", "max", "success-rate", "count"] },
        "operator": { "enum": ["eq", "gte", "lte"] },
        "value": { "type": ["string", "number", "boolean"] },
        "sourceClasses": { "$ref": "#/$defs/SourceClasses" }
      },
      "allOf": [
        {
          "if": { "properties": { "operator": { "enum": ["gte", "lte"] } }, "required": ["operator"] },
          "then": { "properties": { "value": { "type": "number" } } }
        }
      ]
    },
    "RankPreference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["measurementKey", "aggregation", "direction", "weight"],
      "properties": {
        "measurementKey": { "type": "string", "minLength": 1, "maxLength": 256, "pattern": "^(?=\\S)(?!.*[\\u0000-\\u001f]).*\\S$" },
        "aggregation": { "enum": ["fact", "mean", "min", "max", "success-rate", "count"] },
        "direction": { "enum": ["maximize", "minimize"] },
        "weight": { "type": "number", "exclusiveMinimum": 0, "maximum": 1000000 },
        "sourceClasses": { "$ref": "#/$defs/SourceClasses" }
      }
    }
  }
}
