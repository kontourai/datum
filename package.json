{
  "name": "@kontourai/datum",
  "version": "0.6.0",
  "description": "Portfolio AI provider/model registry: define providers, models, roles once; resolve which backend, which model, whose key, what base URL. Never makes model calls.",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kontourai/datum.git"
  },
  "homepage": "https://github.com/kontourai/datum#readme",
  "bugs": {
    "url": "https://github.com/kontourai/datum/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "bin": {
    "datum": "bin/datum.mjs"
  },
  "files": [
    "dist/src/",
    "bin/",
    "datum.schema.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc",
    "prepare": "npm run build",
    "prepublishOnly": "npm run verify",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && node --test dist/tests/*.test.js",
    "check:pack": "node scripts/check-package-contents.mjs",
    "check:decisions": "node scripts/check-decisions.cjs check",
    "gen:decisions-index": "node scripts/check-decisions.cjs gen-index",
    "freeze:adrs": "node scripts/freeze-adrs.mjs",
    "verify": "npm run check:decisions && npm run typecheck && npm test && npm run check:pack"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=22"
  }
}
